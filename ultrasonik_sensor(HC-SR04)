#define trig 2        //sensörü ve ledi tanımladık
#define echo 3
#define led 7

int sure = 0;
int mesafe = 0;

void setup() {
pinMode(trig, OUTPUT);     
pinMode(echo, INPUT);      
pinMode(led, OUTPUT);
Serial.begin(9600);

}

void loop() {
digitalWrite(trig, HIGH);    //ses dalgalarını gönderiyor
delayMicroseconds(1000);     
digitalWrite(trig,LOW);      //ses dalgaları geri geliyor


sure = pulseIn(echo, HIGH);
mesafe = (sure/2) / 29.1;

Serial.print("Mesafe:  ");
Serial.print(mesafe);
Serial.println("  cm");
delay(250);

if(mesafe<50){
digitalWrite(led,HIGH);
delay(70);

}
else {
digitalWrite(led, LOW);

}

}
